{
  "name": "gamer-demo1",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:client": "npm run dev --workspace client",
    "dev:server": "npm run dev --workspace server",
    "build": "npm run build --workspace shared && npm run build --workspace server && npm run build --workspace client",
    "typecheck": "npm run typecheck --workspace shared && npm run typecheck --workspace server && npm run typecheck --workspace client",
    "validate:carry-loop": "tsx scripts/validate-carry-loop.ts",
    "validate:profile-carry": "tsx scripts/validate-profile-carry.ts",
    "validate:extract-service": "tsx scripts/validate-extract-service.ts",
    "validate:boss-loop": "tsx scripts/validate-boss-loop.ts",
    "validate:monster-assets": "tsx scripts/validate-monster-asset-contract.ts",
    "validate:combat-readability": "tsx scripts/validate-combat-readability.ts",
    "validate:map-hazards": "tsx scripts/validate-map-hazards.ts",
    "validate:lock-assist": "tsx scripts/validate-lock-assist.ts",
    "validate:dev-room-presets": "tsx scripts/validate-dev-room-presets.ts",
    "validate:dev-cors-contract": "tsx scripts/validate-dev-cors-contract.ts",
    "validate:room-loadout-contract": "tsx scripts/validate-room-loadout-contract.ts",
    "validate:market-lifecycle": "tsx scripts/validate-market-lifecycle.ts",
    "validate:responsive-scaling": "tsx scripts/validate-responsive-scaling.ts",
    "validate:inventory-drag-contract": "tsx scripts/validate-inventory-drag-contract.ts",
    "validate:profile-drag-contract": "tsx scripts/validate-profile-drag-contract.ts",
    "validate:inventory-drag-ui": "tsx scripts/validate-inventory-drag-ui.ts",
    "validate:chest-contract": "tsx scripts/validate-chest-contract.ts",
    "validate:visual-clarity": "tsx scripts/validate-visual-clarity.ts",
    "validate:hud-ui": "tsx scripts/validate-hud-ui.ts",
    "validate:mobile-controls-contract": "tsx scripts/validate-mobile-controls-contract.ts",
    "validate:drag-contracts": "npm run validate:inventory-drag-contract && npm run validate:profile-drag-contract && npm run validate:inventory-drag-ui",
    "accept:game-feel": "node scripts/accept-game-feel-baseline.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "playwright": "^1.59.1"
  }
}
